use biblioteca

db.createCollection("libros", {
  validator: {
    $jsonSchema: {
      bsonType: "object",
      required: ["titulo", "autor", "isbn", "anioPublicacion", "disponible", "categorias"],
      properties: {
        titulo: { bsonType: "string" },
        autor: { bsonType: "string" },
        isbn: {
          bsonType: "string",
          pattern: "^[0-9]{3}-[0-9]{10}$"
        },
        anioPublicacion: {
          bsonType: "int",
          minimum: 1900,
          maximum: 2025
        },
        disponible: { bsonType: "bool" },
        categorias: {
          bsonType: "array",
          minItems: 1,
          items: { bsonType: "string" }
        }
      }
    }
  }
})

db.createCollection("prestamos")

